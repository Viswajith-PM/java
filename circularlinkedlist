    }

    public static void main(String[] args) {
        circularlinkedlist<String> list = new circularlinkedlist<>();

        list.insertAtBegining("jithu");
        list.insertAtBegining("viswa");
        list.insertAtBegining("chinju");

        list.display();

        list.insertAtEnd("Ajuu");

        System.out.println("After insertion at end:");
        list.display();

        System.out.println("Deleted: " + list.deleteAtBegining());

        System.out.println("After deletion:");
        list.display();
    }
}
