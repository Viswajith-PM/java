public class SmallestElement {
    public static void main(String[] args) {
        int[] arr = {12, 5, 8, 20, 3, 15};

        int largest = arr[0];

        for (int i = 1; i < arr.length; i++) {
            if (arr[i] > largest) {
                largest = arr[i];
            }
        }

        System.out.println("largest  Element: " + largest);
    }
}
